{
  "page": "Checkout",
  "layout": {
    "type": "two-column",
    "columns": [
      { "id": "left", "width": "60%", "sections": ["reviewItemAndShipping", "deliveryInformation"] },
      { "id": "right", "width": "40%", "sections": ["orderSummary"] }
    ]
  },
  "theme": {
    "colors": {
      "background": "#ffffff",
      "surface": "#ffffff",
      "surfaceMuted": "#f5f5f5",
      "border": "#e5e7eb",
      "textPrimary": "#111827",
      "textSecondary": "#9ca3af",
      "textLabel": "#374151",
      "accent": "#1a3d2b",
      "accentText": "#ffffff",
      "selectedRadio": "#1a3d2b",
      "unselectedRadio": "#d1d5db",
      "cardHighlight": "#dcfce7"
    },
    "typography": {
      "headingLarge": { "fontSize": "22px", "fontWeight": "700", "color": "textPrimary" },
      "headingMedium": { "fontSize": "18px", "fontWeight": "700", "color": "textPrimary" },
      "productName": { "fontSize": "18px", "fontWeight": "700", "color": "textPrimary" },
      "price": { "fontSize": "18px", "fontWeight": "600", "color": "textPrimary" },
      "label": { "fontSize": "14px", "fontWeight": "600", "color": "textLabel" },
      "value": { "fontSize": "14px", "fontWeight": "400", "color": "textSecondary" },
      "body": { "fontSize": "14px", "fontWeight": "400", "color": "textPrimary" }
    },
    "spacing": {
      "cardPadding": "24px",
      "sectionGap": "16px",
      "rowGap": "12px",
      "columnGap": "24px"
    },
    "borderRadius": {
      "card": "12px",
      "button": "999px",
      "input": "8px",
      "productImage": "8px"
    },
    "shadows": {
      "card": "0 1px 4px rgba(0,0,0,0.06)"
    }
  },
  "sections": {
    "reviewItemAndShipping": {
      "id": "reviewItemAndShipping",
      "title": "Review Item And Shipping",
      "titleStyle": "headingLarge",
      "border": true,
      "borderColor": "border",
      "borderRadius": "card",
      "padding": "cardPadding",
      "items": [
        {
          "id": "cartItem1",
          "type": "cartItem",
          "image": {
            "src": "airpods_max_pink.png",
            "alt": "AirPods Max - Pink",
            "backgroundColor": "surfaceMuted",
            "width": "100px",
            "height": "100px",
            "borderRadius": "productImage"
          },
          "name": "Airpods- Max",
          "nameStyle": "productName",
          "attributes": [
            { "key": "Color", "value": "Pink" }
          ],
          "price": "$549.00",
          "priceStyle": "price",
          "quantity": {
            "label": "Quantity",
            "value": "01"
          }
        }
      ]
    },
    "deliveryInformation": {
      "id": "deliveryInformation",
      "title": "Delivery Information",
      "titleStyle": "headingLarge",
      "border": true,
      "borderColor": "border",
      "borderRadius": "card",
      "padding": "cardPadding",
      "actions": [
        {
          "id": "editInformation",
          "label": "Edit Information",
          "type": "button",
          "variant": "ghost",
          "style": {
            "backgroundColor": "surfaceMuted",
            "borderRadius": "button",
            "fontSize": "13px",
            "fontWeight": "500",
            "padding": "8px 16px"
          }
        }
      ],
      "fields": [
        { "label": "Name", "value": "Wade Warren" },
        { "label": "Address", "value": "4140 Parker Rd. Allentown, New Mexico 31134" },
        { "label": "City", "value": "Austin" },
        { "label": "Zip Code", "value": "85486" },
        { "label": "Mobile", "value": "+447700960054" },
        { "label": "Email", "value": "georgia.young@example.com" }
      ],
      "fieldLayout": {
        "type": "key-value-rows",
        "labelStyle": "label",
        "valueStyle": "value",
        "rowGap": "12px"
      }
    },
    "orderSummary": {
      "id": "orderSummary",
      "title": "Order Summery",
      "titleStyle": "headingLarge",
      "border": false,
      "padding": "cardPadding",
      "subsections": [
        {
          "id": "coupon",
          "type": "couponInput",
          "input": {
            "placeholder": "Enter Coupon Code",
            "backgroundColor": "surfaceMuted",
            "borderRadius": "input",
            "padding": "12px 16px",
            "fontSize": "14px",
            "color": "textSecondary"
          },
          "button": {
            "label": "Apply coupon",
            "backgroundColor": "accent",
            "textColor": "accentText",
            "borderRadius": "button",
            "fontSize": "14px",
            "fontWeight": "600",
            "padding": "12px 20px"
          }
        },
        {
          "id": "paymentDetails",
          "title": "Payment Details",
          "titleStyle": "headingMedium",
          "type": "radioGroup",
          "options": [
            {
              "id": "cashOnDelivery",
              "label": "Cash on Delivery",
              "selected": false
            },
            {
              "id": "shopcartCard",
              "label": "Shopcart Card",
              "selected": false
            },
            {
              "id": "paypal",
              "label": "Paypal",
              "selected": false
            },
            {
              "id": "creditDebitCard",
              "label": "Credit or Debit card",
              "selected": true,
              "subContent": {
                "type": "cardBrands",
                "brands": [
                  {
                    "id": "amazon",
                    "label": "Amazon Pay",
                    "logoType": "text",
                    "logoText": "amazon",
                    "style": { "border": "none" }
                  },
                  {
                    "id": "mastercard",
                    "label": "Mastercard",
                    "logoType": "icon",
                    "style": { "border": "2px solid #22c55e", "borderRadius": "6px", "padding": "4px 8px" }
                  },
                  {
                    "id": "visa",
                    "label": "Visa",
                    "logoType": "text",
                    "logoText": "VISA",
                    "style": { "border": "none", "fontSize": "20px", "fontWeight": "700", "color": "#1a1aff" }
                  }
                ]
              },
              "fields": [
                {
                  "id": "email",
                  "label": "Email*",
                  "type": "text",
                  "placeholder": "Type here...",
                  "required": true
                },
                {
                  "id": "cardHolderName",
                  "label": "Card Holder Name*",
                  "type": "text",
                  "placeholder": "Type here...",
                  "required": true
                }
              ]
            }
          ],
          "radioStyle": {
            "selectedColor": "selectedRadio",
            "unselectedColor": "unselectedRadio",
            "labelStyle": "body",
            "gap": "12px"
          }
        }
      ]
    }
  },
  "components": {
    "input": {
      "backgroundColor": "surfaceMuted",
      "border": "none",
      "borderRadius": "input",
      "padding": "12px 16px",
      "fontSize": "14px",
      "placeholderColor": "textSecondary",
      "focusBorder": "1px solid accent"
    },
    "radioButton": {
      "size": "18px",
      "selectedFillColor": "selectedRadio",
      "unselectedBorderColor": "unselectedRadio",
      "labelGap": "10px"
    },
    "card": {
      "backgroundColor": "surface",
      "border": "1px solid border",
      "borderRadius": "card",
      "padding": "cardPadding",
      "shadow": "card"
    },
    "primaryButton": {
      "backgroundColor": "accent",
      "textColor": "accentText",
      "borderRadius": "button",
      "fontWeight": "600",
      "padding": "12px 24px",
      "hoverOpacity": 0.9
    },
    "ghostButton": {
      "backgroundColor": "surfaceMuted",
      "textColor": "textPrimary",
      "borderRadius": "button",
      "fontWeight": "500",
      "padding": "8px 16px"
    }
  }
}
