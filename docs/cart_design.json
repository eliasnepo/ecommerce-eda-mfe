{
  "meta": {
    "spec_id": "006",
    "name": "cart_checkout_shopcart_style",
    "source": "Image 3",
    "last_updated": "2026-04-13"
  },
  "page": {
    "type": "cart_checkout",
    "background_color": "#FFFFFF",
    "layout": "review_plus_payment",
    "max_width": "1320px",
    "sections": [
      "review_item_shipping",
      "order_summary",
      "payment_details"
    ]
  },
  "layout": {
    "desktop": {
      "columns": "1.7fr 1fr",
      "gap": "24px",
      "align": "start"
    },
    "tablet": {
      "columns": "1fr",
      "gap": "20px"
    },
    "mobile": {
      "columns": "1fr",
      "gap": "16px"
    }
  },
  "sections": {
    "review_item_shipping": {
      "header": {
        "text": "Review Item And Shipping",
        "font_size": "18px",
        "font_weight": "700",
        "color": "#111827"
      },
      "product_card": {
        "background": "#FFFFFF",
        "border": "1px solid #E5E7EB",
        "border_radius": "10px",
        "padding": "18px",
        "layout": "image_info_price",
        "image": {
          "size": "180px",
          "background": "#F3F4F6",
          "border_radius": "10px",
          "object_fit": "contain"
        },
        "product_name": {
          "font_size": "28px",
          "font_weight": "700",
          "color": "#111827"
        },
        "variant_text": {
          "template": "Color: {colorName}",
          "font_size": "16px",
          "color": "#4B5563"
        },
        "price": {
          "font_size": "24px",
          "font_weight": "700",
          "format": "$0.00"
        },
        "quantity": {
          "template": "Quantity: {quantity}",
          "font_size": "16px",
          "font_weight": "600",
          "format": "02"
        }
      },
      "delivery_information": {
        "header": {
          "text": "Delivery Information",
          "font_size": "18px",
          "font_weight": "700"
        },
        "edit_action": {
          "label": "Edit Information",
          "style": "gray_pill"
        },
        "rows": [
          "Name",
          "Address",
          "City",
          "Zip Code",
          "Mobile",
          "Email"
        ],
        "row_style": {
          "label_weight": "600",
          "value_color": "#6B7280"
        }
      }
    },
    "order_summary": {
      "header": {
        "text": "Order Summery",
        "font_size": "18px",
        "font_weight": "700"
      },
      "coupon": {
        "input_placeholder": "Enter Coupon Code",
        "apply_button": {
          "label": "Apply coupon",
          "background": "#00553A",
          "text_color": "#FFFFFF",
          "shape": "pill"
        }
      }
    },
    "payment_details": {
      "header": {
        "text": "Payment Details",
        "font_size": "18px",
        "font_weight": "700"
      },
      "methods": [
        {
          "key": "cod",
          "label": "Cash on Delivery",
          "type": "radio"
        },
        {
          "key": "shopcart_card",
          "label": "Shopcart Card",
          "type": "radio"
        },
        {
          "key": "paypal",
          "label": "Paypal",
          "type": "radio"
        },
        {
          "key": "credit_debit",
          "label": "Credit or Debit card",
          "type": "radio",
          "selected": true
        }
      ],
      "card_brand_row": [
        "amazon",
        "mastercard",
        "visa"
      ],
      "card_form": {
        "fields": [
          {
            "key": "email",
            "label": "Email*",
            "placeholder": "Type here..."
          },
          {
            "key": "card_holder_name",
            "label": "Card Holder Name*",
            "placeholder": "Type here..."
          },
          {
            "key": "card_number",
            "label": "Card Number*",
            "placeholder": "0000 0000 0000 0000"
          },
          {
            "key": "expiry",
            "label": "Expiry*",
            "placeholder": "MM/YY"
          },
          {
            "key": "cvv",
            "label": "CVV*",
            "placeholder": "123"
          }
        ]
      },
      "primary_cta": {
        "label": "Place Order",
        "height": "48px",
        "background": "#00553A",
        "text_color": "#FFFFFF",
        "border_radius": "999px"
      }
    }
  },
  "empty_state": {
    "title": "Your cart is empty",
    "description": "Add products to continue checkout.",
    "cta": {
      "label": "Continue Shopping",
      "target": "/catalog"
    }
  },
  "design_tokens": {
    "colors": {
      "brand_primary": "#00553A",
      "text_primary": "#111827",
      "text_secondary": "#6B7280",
      "surface": "#FFFFFF",
      "surface_muted": "#F3F4F6",
      "border": "#E5E7EB",
      "radio_active": "#00A63E"
    },
    "typography": {
      "font_family": "Poppins, sans-serif",
      "page_heading": {
        "size": "18px",
        "weight": "700"
      },
      "product_name": {
        "size": "28px",
        "weight": "700"
      },
      "label": {
        "size": "16px",
        "weight": "600"
      },
      "body": {
        "size": "16px",
        "weight": "400"
      }
    },
    "radius": {
      "card": "10px",
      "input": "8px",
      "pill": "999px"
    },
    "spacing": {
      "section_gap": "20px",
      "card_padding": "18px",
      "field_gap": "14px"
    },
    "shadows": {
      "card": "none"
    }
  },
  "interaction_patterns": {
    "coupon_apply": {
      "trigger": "click_apply_coupon",
      "behavior": "validates_coupon_and_updates_totals"
    },
    "payment_method_selection": {
      "trigger": "radio_select",
      "behavior": "switches_payment_form_state"
    },
    "edit_delivery_info": {
      "trigger": "click_edit_information",
      "behavior": "opens_delivery_editor"
    },
    "place_order": {
      "trigger": "click_place_order",
      "states": [
        "idle",
        "loading",
        "success",
        "error"
      ]
    }
  },
  "sample_data": {
    "item": {
      "name": "Airpods- Max",
      "color": "Pink",
      "price": 549.0,
      "quantity": 1
    },
    "delivery_info": {
      "name": "Wade Warren",
      "address": "4140 Parker Rd. Allentown, New Mexico 31134",
      "city": "Austin",
      "zipCode": "85486",
      "mobile": "+447700960054",
      "email": "georgia.young@example.com"
    }
  }
}
