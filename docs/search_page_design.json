          "price": 734.60,
          "currency": "AED",
          "row": 1
        },
        {
          "id": 4,
          "name": "Rowing Blazers Bright Multicolor Colorblock…",
          "rating": 4.5,
          "review_count": 88,
          "price": 1469.20,
          "currency": "AED",
          "row": 1
        },
        {
          "id": 5,
          "name": "U.S. Polo Assn. Women's Crop Color-Blocked Puffer…",
          "rating": 3.5,
