          "price": 609.36,
          "currency": "AED",
          "row": 2
        },
        {
          "id": 7,
          "name": "Only Padded Coat in Pink & Red Color block-Multi",
          "rating": 2.5,
          "review_count": 16,
          "price": 209.36,
          "currency": "AED",
          "row": 2
        },
        {
          "id": 8,
          "name": "Off Road Ventures Women's Lightweight…",
          "rating": 4.5,
          "review_count": 1100,
          "price": 624.41,
          "currency": "AED",
          "row": 2
        },
        {
          "id": 9,
          "name": "Rowing Blazers Bright Multicolor Colorblock…",
          "rating": 2.0,
          "review_count": 64,
          "price": 455.45,
          "currency": "AED",
          "row": 2
        },
        {
          "id": 10,
          "name": "U.S. Polo Assn. Women's Crop Color-Blocked Puffer…",
          "rating": 3.5,
          "review_count": 200,
          "price": 253.44,
          "currency": "AED",
          "row": 2
        }
      ]
    }
  },

  "design_tokens": {
    "colors": {
      "primary_text": "#111827",
      "secondary_text": "#6B7280",
      "link": "#1D4ED8",
      "star_filled": "#F59E0B",
      "star_empty": "#D1D5DB",
      "card_background": "#FFFFFF",
      "page_background": "#F0F2F5",
      "border": "#D1D5DB",
      "wishlist_icon": "#9CA3AF"
    },
    "typography": {
      "section_heading": { "size": "20px", "weight": "700" },
      "filter_label": { "size": "14px", "weight": "400" },
      "store_name": { "size": "15px", "weight": "600" },
      "product_name": { "size": "13px", "weight": "500" },
      "product_price": { "size": "15px", "weight": "700" },
      "review_count": { "size": "12px", "weight": "400" },
      "cta_link": { "size": "13px", "weight": "400" }
    },
    "spacing": {
      "section_gap": "24px",
      "card_gap": "16px",
      "card_padding": "10px",
      "filter_pill_padding": "6px 14px"
    },
    "border_radius": {
      "card": "12px",
      "pill": "999px",
      "thumbnail": "50%"
    }
  },

  "interaction_patterns": {
    "wishlist_toggle": {
      "trigger": "click",
      "target": "heart_icon",
      "states": ["outline (default)", "filled_red (saved)"]
    },
    "filter_dropdown": {
      "trigger": "click",
      "behavior": "overlay_menu"
    },
    "store_scroll": {
      "trigger": "click_arrow or swipe",
      "behavior": "horizontal_scroll"
    },
    "view_all": {
      "trigger": "click",
      "behavior": "navigate_to_full_list"
    }
  }
}
