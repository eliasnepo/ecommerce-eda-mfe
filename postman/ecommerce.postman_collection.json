                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{gateway_url}}/api/ai/recommendations/{{user_id}}",
                  "host": ["{{gateway_url}}"],
                  "path": ["api", "ai", "recommendations", "{{user_id}}"]
                },
                "description": "Fetches AI-powered product recommendations via the gateway → Recommendations AI Service. Builds a prompt from the user's last 10 orders and calls Ollama (llama3.2). Returns `{ userId, historyOrdersUsed, insights, recommendations: [{ productName, category, reason }] }` with up to 3 products. First call may take 15–60 s on CPU-only Ollama. 502 is returned if Ollama is unavailable."
              },
              "response": []
            }
          ]
        }
