        {
          "name": "Orders (via Gateway)",
          "description": "REST requests routed through the gateway to Order Service (:8082). ⚠️ Order Service not yet implemented — Phase 6.",
          "item": [
            {
              "name": "Place Order",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "const json = pm.response.json();",
                      "if (json?.id) {",
                      "    pm.environment.set('order_id', json.id);",
                      "}",
                      "pm.test('X-Correlation-Id header is present', () => {",
