              ],
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"userId\": {{user_id}},\n  \"items\": [\n    {\n      \"productId\": \"{{product_id}}\",\n      \"productName\": \"Wireless Headphones\",\n      \"unitPrice\": 49.99,\n      \"quantity\": 2\n    }\n  ]\n}"
                },
                "url": {
                  "raw": "{{gateway_url}}/api/orders",
                  "host": ["{{gateway_url}}"],
                  "path": ["api", "orders"]
                },
                "description": "Places a new order via the gateway → Order Service. Saves the returned `id` into `{{order_id}}`."
              },
