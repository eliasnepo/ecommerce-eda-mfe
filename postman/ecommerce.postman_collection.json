        {
          "name": "Products (via Gateway)",
          "description": "GraphQL requests routed through the gateway to Product Service (:8081). Every response includes an `X-Correlation-Id` header generated by CorrelationIdFilter.",
          "item": [
            {
              "name": "Get All Products",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "const json = pm.response.json();",
                      "const content = json?.data?.products?.content;",
                      "if (content && content.length > 0) {",
                      "    pm.environment.set('product_id', content[0].id);",
                      "}",
                      "pm.test('X-Correlation-Id header is present', () => {",
                      "    pm.response.to.have.header('X-Correlation-Id');",
                      "});"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"query\": \"{ products { content { id name price category imageUrl } totalElements totalPages currentPage } }\"\n}"
                },
                "url": {
                  "raw": "{{gateway_url}}/graphql",
                  "host": ["{{gateway_url}}"],
                  "path": ["graphql"]
                },
                "description": "Proxied to Product Service. Returns first page of all products. Saves the first result's `id` into `{{product_id}}`. Asserts that `X-Correlation-Id` is present on the response (generated by CorrelationIdFilter)."
